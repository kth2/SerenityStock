{
  "name": "serenity-stock-tracker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "PWA that tracks @aleabitoreddit (Serenity) stock mentions and applies the Serenity supply-chain bottleneck research skill",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "scrape": "node scripts/scrape.mjs",
    "process": "node scripts/process.mjs",
    "quotes": "node scripts/quotes.mjs",
    "analyze": "node scripts/analyze.mjs",
    "pipeline": "npm run scrape && npm run process && npm run quotes && npm run analyze",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.525.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.112.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.53.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.1"
  }
}
